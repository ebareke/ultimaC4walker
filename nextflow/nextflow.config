/*
 * ultimaC4walker Nextflow configuration.
 */

manifest {
    name            = 'ultimaC4walker'
    author          = 'Eric Bareke, Ethan M., Conrad B.'
    homePage        = 'https://ebareke.github.io/ultimaC4walker/'
    description     = 'FASTQ to chromatin peaks/QC — ChIP-seq, CUT&RUN, CUT&Tag, ATAC-seq'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

params {
    samplesheet       = null
    fasta             = null
    bwa_index         = null          // optional: skip BWA_INDEX if provided
    blacklist         = null          // optional ENCODE blacklist BED
    outdir            = 'results'
    project           = 'c4walker_nf'
    genome_size       = 'hs'
    mito_chr          = 'chrM'
    min_mapq          = 30
    remove_duplicates = 1
    container         = 'ghcr.io/ebareke/ultimac4walker:1.0.0'
}

process {
    container = params.container

    withLabel: 'index'        { cpus = 8; memory = 32.GB; time = '6h' }
    withLabel: 'process_high' { cpus = 8; memory = 32.GB; time = '8h' }
    withLabel: 'process_low'  { cpus = 2; memory =  8.GB; time = '2h' }
}

profiles {
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
    }
    conda {
        conda.enabled = true
    }
    test {
        params.samplesheet = "${projectDir}/../example/data/samplesheet.csv"
        params.fasta       = "${projectDir}/../example/data/reference.fa"
        params.genome_size = '10000'
        params.mito_chr    = ''
        params.min_mapq    = 0
        params.outdir      = 'test_results'
        // Cap the per-process requests so the pipeline fits a small CI runner
        // (GitHub runners: 4 CPUs / ~16 GB). resourceLimits scales every
        // request down to these ceilings without touching the HPC defaults.
        process.resourceLimits = [ cpus: 2, memory: '6.GB', time: '1.h' ]
    }
}

timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html" }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt" }
